# ===========================================
# DentaTrak Environment Configuration
# ===========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ===========================================

# Encryption key for sensitive data (generate a random 64-character hex string)
ENCRYPTION_KEY=your_64_character_hex_encryption_key_here

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# Local Development Database credentials (MAMP)
DB_USER_LOCAL=root
DB_PASSWORD_LOCAL=root

# UAT/Production Database credentials
DB_USER=your_database_username
DB_PASSWORD=your_database_password
DB_NAME=dental_case_tracker

# ===========================================
# GOOGLE API CREDENTIALS
# ===========================================
# Get these from Google Cloud Console: https://console.cloud.google.com/

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_API_KEY=your_google_api_key

# ===========================================
# AI PROVIDER CONFIGURATION
# ===========================================

# AI Provider: 'openai' or 'gemini'
AI_PROVIDER=gemini

# OpenAI API credentials (if using OpenAI)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# Gemini API credentials (if using Gemini)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ===========================================
# STRIPE PAYMENT CONFIGURATION
# ===========================================
# Get these from Stripe Dashboard: https://dashboard.stripe.com/apikeys

STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PRICING_TABLE_ID=prctbl_your_pricing_table_id
STRIPE_PRICING_TABLE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ===========================================
# EMAIL CONFIGURATION (SendGrid)
# ===========================================
# Get from: https://app.sendgrid.com/settings/api_keys

SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=DentaTrak

# ===========================================
# DEV TOOLS CONFIGURATION
# ===========================================

# Set to 'true' to enable dev tools for super users in UAT/Production
DEV_TOOLS_ENABLED=false

# Comma-separated list of super user emails who can access dev tools
SUPER_USERS=admin@yourdomain.com
